# Zero-Knowledge Provider Configuration
# This file maps service capabilities to actual provider status pages
# NEVER commit the actual .env.local file to version control

# ============================================================================
# PROVIDER CONFIGURATION
# ============================================================================
# Each provider is configured with:
# - SERVICE_ID: Maps to service in lib/core/service-capabilities.ts
# - STATUS_URL: The public status page URL
# - API_ENDPOINT: The API endpoint for status data
# - FETCH_STRATEGY: How to parse the status data (atlassian, exa, google, aws, custom)
# - COMPONENT_MAP: JSON mapping of vendor component IDs to our component IDs

# Provider 1: Advanced Reasoning AI
# Maps to: llm-advanced-reasoning service
PROVIDER_1_SERVICE_ID=llm-advanced-reasoning
PROVIDER_1_STATUS_URL=https://status.anthropic.com
PROVIDER_1_API_ENDPOINT=https://status.anthropic.com/api/v2/summary.json
PROVIDER_1_FETCH_STRATEGY=atlassian
PROVIDER_1_COMPONENT_MAP={"bh014xh9wv0k":"llm-adv-api","5x4l53vs2x9r":"llm-adv-streaming"}

# Provider 2: General Purpose AI
# Maps to: llm-general-purpose service
PROVIDER_2_SERVICE_ID=llm-general-purpose
PROVIDER_2_STATUS_URL=https://status.openai.com
PROVIDER_2_API_ENDPOINT=https://status.openai.com/api/v2/summary.json
PROVIDER_2_FETCH_STRATEGY=atlassian
PROVIDER_2_COMPONENT_MAP={"kr09ddfgbfsf":"llm-gen-api","vg70hn9s2tyj":"llm-gen-chat"}

# Provider 3: Web Research Service
# Maps to: web-research-service
PROVIDER_3_SERVICE_ID=web-research-service
PROVIDER_3_STATUS_URL=https://status.exa.ai
PROVIDER_3_API_ENDPOINT=https://status.exa.ai/api/v2/summary.json
PROVIDER_3_FETCH_STRATEGY=exa
PROVIDER_3_COMPONENT_MAP={"exa-main":"web-search-api"}

# Provider 4: Cloud Infrastructure
# Maps to: cloud-infrastructure service
PROVIDER_4_SERVICE_ID=cloud-infrastructure
PROVIDER_4_STATUS_URL=https://health.aws.amazon.com/health/status
PROVIDER_4_API_ENDPOINT=https://status.aws.amazon.com/data.json
PROVIDER_4_FETCH_STRATEGY=aws
PROVIDER_4_COMPONENT_MAP={"us-east-1-ec2":"cloud-compute","us-east-1-api-gateway":"cloud-api-gateway"}

# Provider 5: Multimodal AI
# Maps to: llm-multimodal service
PROVIDER_5_SERVICE_ID=llm-multimodal
PROVIDER_5_STATUS_URL=https://status.cloud.google.com
PROVIDER_5_API_ENDPOINT=https://status.cloud.google.com/incidents.json
PROVIDER_5_FETCH_STRATEGY=google
PROVIDER_5_COMPONENT_MAP={"vertex-ai":"llm-multi-api","vision-api":"llm-multi-vision"}

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Enable console sanitization (recommended: true)
# This automatically scrubs vendor names from all console.log output
ENABLE_CONSOLE_SANITIZATION=true

# Enable API response sanitization (recommended: true)
# This automatically scrubs vendor names from all API responses
ENABLE_API_SANITIZATION=true

# Enable strict mode (recommended: true in production)
# In strict mode, any vendor reference found triggers a warning
SANITIZATION_STRICT_MODE=false

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Enable service capability filtering
# Only show services with these capabilities on the dashboard
# Options: text-generation, reasoning, vision, web-search, embeddings, function-calling
# Leave empty to show all services
SERVICE_CAPABILITY_FILTER=

# Service priority filter
# Options: primary, secondary, optional
# Leave empty to show all priorities
SERVICE_PRIORITY_FILTER=primary

# ============================================================================
# CACHE SETTINGS
# ============================================================================

# Status cache duration (seconds)
STATUS_CACHE_DURATION=60

# Enable status caching
ENABLE_STATUS_CACHE=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Show sanitization warnings in development
DEV_SHOW_SANITIZATION_WARNINGS=true

# Log provider fetch errors in development
DEV_LOG_PROVIDER_ERRORS=true

# ============================================================================
# NOTES
# ============================================================================
#
# To add a new provider:
# 1. Define the service in lib/core/service-capabilities.ts
# 2. Add PROVIDER_N_* environment variables here
# 3. Create component mappings from vendor IDs to your component IDs
# 4. Choose the appropriate fetch strategy
#
# To find vendor component IDs:
# 1. Visit the provider's status API endpoint
# 2. Look for the "components" array in the JSON response
# 3. Map each vendor component ID to your service component ID
#
# Example component mapping:
# Vendor API returns: {"id":"abc123","name":"Chat Completions API"}
# Your service has: {"componentId":"llm-gen-chat","displayName":"Chat API"}
# Mapping: {"abc123":"llm-gen-chat"}
