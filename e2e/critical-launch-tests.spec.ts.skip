import { test, expect } from '@playwright/test';

/**
 * CRITICAL PRE-LAUNCH TESTS
 * Tests all security fixes and role normalization from latest build
 *
 * Run with: npx playwright test e2e/critical-launch-tests.spec.ts --project=chromium
 */

test.describe('CRITICAL: Authentication & Role System', () => {
  test('Admin login works and displays correct role', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');

    // Fill login form
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');

    // Wait for redirect to dashboard
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Verify logged in - should see dashboard or user menu
    await expect(page).toHaveURL(/\/support\/dashboard/);

    console.log('✅ Admin login successful');
  });

  test('Session persists after page reload', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Reload page
    await page.reload();

    // Should still be on dashboard (not redirected to login)
    await expect(page).toHaveURL(/\/support\/dashboard/);

    console.log('✅ Session persists correctly');
  });
});

