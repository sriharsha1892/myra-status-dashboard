test.describe('CRITICAL: Trial Access & Permissions', () => {
  test('Admin can access trials page', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Navigate to trials
    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    // Should see trials page with table or cards
    await expect(page).toHaveURL(/\/support\/trials/);

    // Check for trial content (table, cards, or empty state)
    const hasContent = await page.locator('table, [role="grid"], [data-testid*="trial"]').count() > 0
      || await page.getByText(/no trials/i).count() > 0;

    expect(hasContent).toBeTruthy();

    console.log('✅ Admin can access trials with data');
  });

  test('Trial detail page loads without errors', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    // Try to find and click first trial (if exists)
    const trialLinks = page.locator('a[href*="/support/trials/"]').first();
    const trialCount = await trialLinks.count();

    if (trialCount > 0) {
      await trialLinks.click();
      await page.waitForLoadState('networkidle');

      // Should be on trial detail page
      await expect(page).toHaveURL(/\/support\/trials\/[^/]+$/);

      console.log('✅ Trial detail page loads successfully');
    } else {
      console.log('⚠️ No trials found to test detail page');
    }
  });
});

test.describe('CRITICAL: User Management', () => {
  test('Users page shows role dropdown with only Admin and Account Manager', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    await page.goto('http://localhost:3000/support/users');
    await page.waitForLoadState('networkidle');

    // Look for "Add User" or similar button
    const addUserButton = page.getByRole('button', { name: /add user|new user|create user/i });

    if (await addUserButton.count() > 0) {
      await addUserButton.click();
      await page.waitForTimeout(500);

      // Look for role dropdown in modal/form
      const roleSelect = page.locator('select, [role="combobox"]').filter({ hasText: /role|type/i }).first();

      if (await roleSelect.count() > 0) {
        const options = await roleSelect.locator('option').allTextContents();

        // Should only contain Admin and Account Manager
        const hasOnlyValidRoles = options.every(opt =>
          opt.includes('Admin') ||
          opt.includes('Account Manager') ||
          opt === '' ||
          opt === 'Select'
        );

        expect(hasOnlyValidRoles).toBeTruthy();

        console.log('✅ Role dropdown contains only Admin and Account Manager');
        console.log('   Available roles:', options);
      }
    } else {
      console.log('⚠️ Add User button not found - check manually');
    }
  });

  test('Users list displays correct normalized roles', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    await page.goto('http://localhost:3000/support/users');
    await page.waitForLoadState('networkidle');

    // Get all role text from the users table
    const roleElements = page.locator('[class*="role"], td:has-text("Admin"), td:has-text("Account Manager")');
    const roleCount = await roleElements.count();

    if (roleCount > 0) {
      const roles = await roleElements.allTextContents();

      // Check that no deprecated roles appear (Team, Product, Viewer, etc.)
      const hasDeprecatedRoles = roles.some(role =>
        role.includes('Team') ||
        role.includes('Product') ||
        role.includes('Viewer') ||
        role.includes('Sales Admin') ||
        role.includes('Research Admin') ||
        role.includes('Prodgain')
      );

      expect(hasDeprecatedRoles).toBeFalsy();

      console.log('✅ No deprecated roles in users list');
      console.log(`   Found ${roleCount} role references`);
    }
  });
});

test.describe('CRITICAL: Error Detection', () => {
  test('No 403 errors on protected routes', async ({ page }) => {
    const errors: string[] = [];

    page.on('response', response => {
      if (response.status() === 403) {
        errors.push(`403 on ${response.url()}`);
      }
    });

    page.on('console', msg => {
      if (msg.type() === 'error') {
        errors.push(`Console error: ${msg.text()}`);
      }
    });

    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Navigate through critical pages
    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    await page.goto('http://localhost:3000/support/users');
    await page.waitForLoadState('networkidle');

    await page.goto('http://localhost:3000/support/tickets');
    await page.waitForLoadState('networkidle');

    // Check for 403 errors
    const has403 = errors.some(e => e.includes('403'));
    expect(has403).toBeFalsy();

    if (errors.length > 0) {
      console.log('⚠️ Errors detected:', errors);
    } else {
      console.log('✅ No 403 errors on protected routes');
    }
  });

  test('No runtime errors on dashboard', async ({ page }) => {
    const consoleErrors: string[] = [];

    page.on('console', msg => {
      if (msg.type() === 'error') {
        consoleErrors.push(msg.text());
      }
    });

    page.on('pageerror', error => {
      consoleErrors.push(`Page error: ${error.message}`);
    });

    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Stay on dashboard for a bit
    await page.waitForTimeout(3000);

    // Filter out non-critical errors (like getSession warnings)
    const criticalErrors = consoleErrors.filter(e =>
      !e.includes('getSession') &&
      !e.includes('Fast Refresh') &&
      !e.includes('Resend')
    );

    if (criticalErrors.length > 0) {
      console.log('⚠️ Runtime errors detected:', criticalErrors);
    } else {
      console.log('✅ No critical runtime errors on dashboard');
    }

    expect(criticalErrors.length).toBeLessThan(3); // Allow some minor errors
  });
});

test.describe('CRITICAL: API Authentication', () => {
  test('API routes require authentication', async ({ page }) => {
    // Try accessing protected API without auth
    const response = await page.request.get('http://localhost:3000/api/todos');

    // Should get 401 Unauthorized
    expect(response.status()).toBe(401);

    console.log('✅ API routes properly reject unauthenticated requests');
  });

  test('Authenticated API calls work correctly', async ({ page }) => {
    // Login first
    await page.goto('http://localhost:3000/support/login');
    await page.fill('input[type="email"]', 'admin@myra.ai');
    await page.fill('input[type="password"]', 'admin@myRA2025');
    await page.click('button[type="submit"]');
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Now API calls should work (authenticated via cookies)
    const response = await page.request.get('http://localhost:3000/api/todos');

    // Should succeed or return empty array
    expect([200, 204]).toContain(response.status());

    console.log('✅ Authenticated API calls work correctly');
  });
});
