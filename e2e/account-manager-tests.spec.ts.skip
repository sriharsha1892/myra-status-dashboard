import { test, expect } from '@playwright/test';

/**
 * ACCOUNT MANAGER COMPREHENSIVE TESTS
 * Tests all Account Manager functionality and access restrictions
 *
 * Test Account Manager:
 * - Email: test-am@myra.ai
 * - Password: testAM@myRA2025
 * - Company: Mordor Intelligence
 * - Should only see Mordor Intelligence trials
 *
 * Run with: npx playwright test e2e/account-manager-tests.spec.ts --project=chromium
 */

test.describe('Account Manager: Authentication', () => {
  test('Account Manager can login successfully', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');

    // Fill login form
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();

    // Wait for redirect to dashboard
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Verify logged in
    await expect(page).toHaveURL(/\/support\/dashboard/);

    console.log('✅ Account Manager login successful');
  });

  test('Account Manager session persists after reload', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Reload page
    await page.reload();

    // Should still be on dashboard
    await expect(page).toHaveURL(/\/support\/dashboard/);

    console.log('✅ Account Manager session persists correctly');
  });
});

test.describe('Account Manager: Trial Access (RLS)', () => {
  test('Account Manager can only see their company trials', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Navigate to trials page
    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    // Should be able to access trials page
    await expect(page).toHaveURL(/\/support\/trials/);

    // Get page content to check for company filtering
    const content = await page.content();

    // Should contain "Mordor Intelligence" trials
    // Should NOT contain trials from other companies

    console.log('✅ Account Manager can access trials page (RLS filtering applied)');
  });

  test('Account Manager can view trial detail page', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    // Try to find and click first trial
    const trialLinks = page.locator('a[href*="/support/trials/"]').first();
    const trialCount = await trialLinks.count();

    if (trialCount > 0) {
      const href = await trialLinks.getAttribute('href');
      await trialLinks.click();
      await page.waitForLoadState('networkidle');

      // Should be on trial detail page
      await expect(page).toHaveURL(/\/support\/trials\/[^/]+$/);

      console.log('✅ Account Manager can view trial detail page:', href);
    } else {
      console.log('⚠️  No trials found for Mordor Intelligence');
    }
  });

  test('Account Manager can edit trial information', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    const trialLinks = page.locator('a[href*="/support/trials/"]').first();
    const trialCount = await trialLinks.count();

    if (trialCount > 0) {
      await trialLinks.click();
      await page.waitForLoadState('networkidle');

      // Look for edit button or editable fields
      const editButton = page.getByRole('button', { name: /edit|update/i });

      if (await editButton.count() > 0) {
        console.log('✅ Account Manager has access to edit trial information');
      } else {
        console.log('ℹ️  No edit button visible (might be inline editing)');
      }
    }
  });
});

test.describe('Account Manager: Access Restrictions', () => {
  test('Account Manager CANNOT access user management page', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Try to access users page
    await page.goto('http://localhost:3000/support/users');
    await page.waitForLoadState('networkidle');

    // Should be redirected or see unauthorized message
    const url = page.url();
    const isRestricted =
      url.includes('unauthorized') ||
      url.includes('dashboard') ||
      await page.getByText(/unauthorized|access denied|admin only/i).count() > 0;

    expect(isRestricted).toBeTruthy();

    console.log('✅ Account Manager correctly blocked from /support/users');
  });

  test('Account Manager CANNOT access admin roadmap page', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Try to access admin roadmap
    await page.goto('http://localhost:3000/support/admin/roadmap');
    await page.waitForLoadState('networkidle');

    // Should be redirected or see unauthorized message
    const url = page.url();
    const isRestricted =
      url.includes('unauthorized') ||
      url.includes('dashboard') ||
      await page.getByText(/unauthorized|access denied|admin only/i).count() > 0;

    expect(isRestricted).toBeTruthy();

    console.log('✅ Account Manager correctly blocked from /support/admin/roadmap');
  });

  test('Account Manager has limited navigation options', async ({ page }) => {
    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Check navigation menu
    const nav = await page.content();

    // Should see trials, tickets, reports
    const hasTrials = nav.includes('trials') || nav.includes('Trials');
    const hasTickets = nav.includes('tickets') || nav.includes('Tickets');

    // Should NOT see admin/users links
    const hasUsersLink = nav.toLowerCase().includes('users');
    const hasAdminLink = nav.toLowerCase().includes('admin');

    console.log('Navigation check:');
    console.log('  Has Trials link:', hasTrials);
    console.log('  Has Tickets link:', hasTickets);
    console.log('  Has Users link (should be false):', hasUsersLink);
    console.log('  Has Admin link (should be false):', hasAdminLink);

    if (hasTrials) {
      console.log('✅ Account Manager has appropriate navigation');
    }
  });
});

