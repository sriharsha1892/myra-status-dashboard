test.describe('Account Manager: Error Detection', () => {
  test('No 403 errors when accessing allowed pages', async ({ page }) => {
    const errors: string[] = [];

    page.on('response', response => {
      if (response.status() === 403) {
        errors.push(`403 on ${response.url()}`);
      }
    });

    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    // Navigate through allowed pages
    await page.goto('http://localhost:3000/support/trials');
    await page.waitForLoadState('networkidle');

    await page.goto('http://localhost:3000/support/tickets');
    await page.waitForLoadState('networkidle');

    await page.goto('http://localhost:3000/support/reports/engagement');
    await page.waitForLoadState('networkidle');

    const has403 = errors.some(e => e.includes('403'));
    expect(has403).toBeFalsy();

    if (errors.length > 0) {
      console.log('⚠️  403 errors detected:', errors);
    } else {
      console.log('✅ No 403 errors on allowed pages');
    }
  });

  test('No runtime errors on Account Manager pages', async ({ page }) => {
    const consoleErrors: string[] = [];

    page.on('console', msg => {
      if (msg.type() === 'error') {
        consoleErrors.push(msg.text());
      }
    });

    page.on('pageerror', error => {
      consoleErrors.push(`Page error: ${error.message}`);
    });

    await page.goto('http://localhost:3000/support/login');
    await page.locator('#email').fill('test-am@myra.ai');
    await page.locator('#password').fill('testAM@myRA2025');
    await page.locator('button[type="submit"]').click();
    await page.waitForURL('**/support/dashboard', { timeout: 10000 });

    await page.goto('http://localhost:3000/support/trials');
    await page.waitForTimeout(2000);

    // Filter out non-critical errors
    const criticalErrors = consoleErrors.filter(e =>
      !e.includes('getSession') &&
      !e.includes('Fast Refresh') &&
      !e.includes('Resend')
    );

    if (criticalErrors.length > 0) {
      console.log('⚠️  Runtime errors:', criticalErrors);
    } else {
      console.log('✅ No critical runtime errors');
    }

    expect(criticalErrors.length).toBeLessThan(3);
  });
});
