# Optional: Default notification webhooks
# These can also be configured via API at runtime

# Slack webhook URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Custom webhook URL (receives JSON payloads on status changes)
# CUSTOM_WEBHOOK_URL=https://your-app.com/webhook

# Cache refresh interval in milliseconds (default: 60000 = 1 minute)
# CACHE_REFRESH_INTERVAL=60000

# Next.js configuration
# PORT=3000
